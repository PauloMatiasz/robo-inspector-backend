import os
#Nao se faz import aqui dentro, nao se colocar os.getenv aqui, isso e apenas um arquivo de texto

#Nomenclatura correta para variaveis de ambiente: NOME_DA_VARIAVEL=valor
ESP32_IP = "192.168.4.1"

#--------------------------------------------------#
#Nomenclatura errada para variaveis de ambiente:
ESP32_IP = os.getenv("ESP32_IP", "192.168.4.1") #Conferir IP do esp32 com adriano
CAMERA_RTSP = os.getenv("CAMERA_RTSP", "rtsp://default") #RTSP da camera 
FLASK_ENV=development
FLASK_PORT=5000 #Porta padrao do flask 
DEBUG=True #Ativar debug do flask 
CORS_ORIGINS=http://localhost:3000 # VERIFICAR ORIGEM DO REACT, NAO ESQUECER 

#.env nao sobe para o github, apenas o .ev.example que tem os campos vazios, para que cada um preencha com suas variaveis de ambiente.
