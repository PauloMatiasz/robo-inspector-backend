FLASK_ENV=development
FLASK_PORT=5000 #Porta padrao do flask 
DEBUG=True #Ativar debug do flask 
CORS_ORIGINS=http://localhost:3000 # VERIFICAR ORIGEM DO REACT, NAO ESQUECER 